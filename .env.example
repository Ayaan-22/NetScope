# NetScope Environment Variables
# Copy this file to .env and fill in your values.

# Scanning options
# NETSCOPE_TIMEOUT=1.5
# NETSCOPE_CONCURRENCY=500
# NETSCOPE_USE_NMAP=1
# NETSCOPE_NMAP_TIMING=4

# Paths and DBs
# NETSCOPE_CVE_DB=config/cve_db.csv
# NETSCOPE_OUTPUT_DIR=reports

# API Keys
# Get your key at https://account.shodan.io/
NETSCOPE_SHODAN_KEY=your_shodan_api_key_here

# Logging
# Choices: DEBUG, INFO, WARNING, ERROR
# NETSCOPE_LOG_LEVEL=INFO
